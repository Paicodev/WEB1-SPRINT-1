<!DOCTYPE html>
<html>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <!--Links a Estilos CSS e iconos-->
    <link rel="stylesheet" href="/css/<%= style %>" />
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css"
    />
    <script
      src="https://kit.fontawesome.com/3c506e0821.js"
      crossorigin="anonymous"
    ></script>
  </head>

  <body>
    <header>
      <!--Logo MiEcommerce-->
      <div class="logo">Mi<span>Ecommerce</span></div>
    </header>

    <main>
      <!--contenedor principal-->
      <div class="main-container">
        <!--fondo verde-->
        <div class="green-background"></div>
        <div class="form-container">
          <!--Formulario de Registro-->
          <form>
            <h2 class="registrate">¡Registrate!</h2>
            <input type="mail" id="mail" placeholder="Tu Mail" />
            <input
              type="password"
              id="password"
              placeholder="Tu nueva contraseña"
            />
            <input
              type="password"
              id="new-password"
              placeholder="Repite tu contraseña"
            />
            <a id="button" href="/"> Crear Cuenta </a>
          </form>
          <!--Link a la página para loguearse-->
        </div>
        <div class="link-login">
          <p>¿Ya tienes Cuenta? <a href="/login"> Inicia Sesion</a></p>
        </div>
      </div>
    </main>

<%- include('../partials/footer') %>
