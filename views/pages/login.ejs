<!DOCTYPE html>
<html>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <!--Links a Estilos CSS e iconos-->
    <link rel="stylesheet" href="/css/<%= style %>" />
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css"
    />
    <script
      src="https://kit.fontawesome.com/3c506e0821.js"
      crossorigin="anonymous"
    ></script>
  </head>

  <body>
    <header>
      <div class="logo">Mi<span>Ecommerce</span></div>
    </header>

    <main>
      <div class="main-container">
        <div class="green-background"></div>
        <div class="form-container">
          <!--Formulario de Registro-->
          <form>
            <h2 class="bienvenida">¡Hola!</h2>
            <label></label>
            <input type="text" id="text" placeholder="Tu nombre de usuario" />
            <label></label>
            <input type="password" id="password" placeholder="Tu contraseña" />
            <a id="button" href="/">Iniciar Sesión</a>
          </form>
          <!--Link a la página para loguearse-->
        </div>
        <div class="link-login">
          <p>¿No tienes Cuenta? <a href="/register"> Registrate</a></p>
        </div>
      </div>
    </main>

    <%- include('../partials/footer') %>